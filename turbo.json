{
  "$schema": "./node_modules/turbo/schema.json",
  "tasks": {
    "generate": {
      "dependsOn": ["^generate"],
      "outputs": ["src/generated/**"]
    },
    "build": {
      "dependsOn": ["^build", "^generate"],
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck", "^generate"]
    }
  }
}
