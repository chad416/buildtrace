NODE_ENV=development

# Web
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# API
API_PORT=4000
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/buildtrace

# Supabase - placeholders only, never commit real secrets
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Redis / worker
REDIS_URL=redis://localhost:6379

# Security
APP_DATA_REGION=eu
SIGNED_URL_TTL_SECONDS=900
