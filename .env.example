NODE_ENV=development

# Web
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# API
API_PORT=4000
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/buildtrace

# Development bootstrap - local/dev only, never production demo data
DEV_ORGANIZATION_NAME=BuildTrace Development
DEV_ORGANIZATION_SLUG=buildtrace-development
DEV_AUTH_USER_ID=00000000-0000-4000-8000-000000000000
DEV_USER_EMAIL=builder@example.com
DEV_USER_DISPLAY_NAME=Development Builder
DEV_ORGANIZATION_ROLE=OWNER

# Supabase - placeholders only, never commit real secrets
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DOCUMENT_STORAGE_BUCKET=buildtrace-documents

# Redis / worker
REDIS_URL=redis://localhost:6379

# Security
APP_DATA_REGION=eu
SIGNED_URL_TTL_SECONDS=900
