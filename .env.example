# Runtime mode used by API/DB development guards. Keep "development" locally.
NODE_ENV=development

# Public web origin used when BuildTrace creates portal links.
# For non-default values, also set this in apps/web/.env.local.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Public NestJS API origin used by the Next.js web client.
# For non-default values, also set this in apps/web/.env.local.
NEXT_PUBLIC_API_URL=http://localhost:4000

# Port on which apps/api listens.
API_PORT=4000

# PostgreSQL connection string from Supabase: Project Settings > Database.
# Replace every placeholder; never commit the real password.
# Local development: use direct connection (port 5432)
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres
#
# Production (Railway): use transaction mode / pgbouncer (port 6543)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.PROJECT_REF.supabase.co:6543/postgres?pgbouncer=true

# Supabase project URL from Project Settings > API.
SUPABASE_URL=

# Public Supabase project URL exposed to the Next.js auth flow.
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon/public JWT from Project Settings > API.
# Used by local auth bootstrap tooling; it is not the service-role key.
SUPABASE_ANON_KEY=

# Public Supabase anon JWT exposed to the Next.js auth flow.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service-role JWT from Project Settings > API.
# Server/API only. Never expose it through NEXT_PUBLIC_* or browser code.
SUPABASE_SERVICE_ROLE_KEY=

# Name of a PRIVATE Supabase Storage bucket created for BuildTrace files.
DOCUMENT_STORAGE_BUCKET=buildtrace-documents

# Lifetime, in seconds, for signed download URLs (accepted range: 60-3600).
SIGNED_URL_TTL_SECONDS=900

# Local-only bootstrap organization. These values seed/upsert development records.
DEV_ORGANIZATION_NAME=BuildTrace Development
DEV_ORGANIZATION_SLUG=buildtrace-development

# UUID of a development user created in Supabase Auth > Users.
DEV_AUTH_USER_ID=00000000-0000-4000-8000-000000000000

# Email and display name for the same development user.
DEV_USER_EMAIL=builder@example.com
DEV_USER_DISPLAY_NAME=Development Builder

# Membership role for the development user: OWNER, ADMIN, or MEMBER.
DEV_ORGANIZATION_ROLE=OWNER

# Optional page opened by the interactive browser-session helper.
DEV_WEB_URL=http://localhost:3000/en/machines

# Comma-separated list of allowed frontend origins for the API CORS policy.
# In production: set to your Vercel deployment URL.
# Example: https://buildtrace.vercel.app
# Leave as localhost for local development.
CORS_ORIGIN=http://localhost:3000
