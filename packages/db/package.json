{
  "name": "@buildtrace/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "activity:smoke": "tsx src/activity-log-smoke-check.ts",
    "dev:bootstrap": "pnpm run generate && tsx src/dev-bootstrap.ts",
    "machine-record:isolation": "pnpm run generate && tsx src/machine-record-isolation-check.ts",
    "machine-records:smoke": "pnpm run generate && tsx src/machine-records-smoke-check.ts",
    "document-schema:drift": "pnpm run generate && tsx src/document-schema-drift-check.ts",
    "document-records:isolation": "pnpm run generate && tsx src/document-records-isolation-check.ts",
    "build": "pnpm run generate && tsc --noEmit",
    "lint": "eslint .",
    "typecheck": "pnpm run generate && tsc --noEmit",
    "data-export-schema:drift": "pnpm run generate && tsx src/data-export-schema-drift-check.ts",
    "data-export-records:isolation": "pnpm run generate && tsx src/data-export-records-isolation-check.ts",
    "qr-portal-schema:drift": "tsx src/qr-portal-schema-drift-check.ts",
    "qr-portal-records:smoke": "tsx src/qr-portal-records-smoke-check.ts"
  },
  "dependencies": {
    "@buildtrace/shared": "workspace:*",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "dotenv": "^17.4.2",
    "prisma": "^7.8.0",
    "tsx": "^4.22.4"
  }
}
