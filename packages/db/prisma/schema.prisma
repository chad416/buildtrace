generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum OrganizationRole {
  OWNER
  ADMIN
  MEMBER
}

enum MachineStatus {
  ACTIVE
  MAINTENANCE
  OUT_OF_SERVICE
  ARCHIVED
}

enum DocumentCategory {
  PLC
  HMI
  MECHANICAL_DRAWINGS
  ELECTRICAL_DRAWINGS
  CAD
  MACHINE_PHOTOS
  FAT
  SAT
  MANUALS
  SAFETY_INSTRUCTIONS
  SUPPLIER_DOCUMENTS
  SPARE_PARTS_BOM
  CERTIFICATES
  SERVICE_NOTES
  OTHER
}

enum DocumentVisibilityLevel {
  CUSTOMER_VISIBLE
  INTERNAL
  SENSITIVE_ENGINEERING
  RESTRICTED
}

enum DocumentLanguage {
  EN
  CS
  SK
  PL
  DE
  FR
  ES
  UNKNOWN
}

enum DocumentClassificationStatus {
  UNCLASSIFIED
  CLASSIFIED
  NEEDS_REVIEW
  MANUALLY_CONFIRMED
}

enum DocumentClassificationSource {
  FILENAME_TYPE
  MANUAL
}

enum DataExportAudience {
  CUSTOMER_HANDOVER
}

enum DataExportResult {
  PENDING
  SUCCEEDED
  FAILED
}

model Organization {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  activityLogs  ActivityLog[]
  customers     Customer[]
  dataExports   DataExport[]
  documents     Document[]
  machineModels MachineModel[]
  machines       Machine[]
  memberships    OrganizationMembership[]
  serviceTickets ServiceTicket[]
  softwareVersions SoftwareVersion[]
  spareParts   SparePart[]
  quoteRequests QuoteRequest[]
  ticketComments TicketComment[]

  @@map("organizations")
}

model AppUser {
  id          String   @id @default(uuid()) @db.Uuid
  authUserId  String   @unique @map("auth_user_id") @db.Uuid
  email       String   @unique
  displayName String?  @map("display_name")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  activityLogs      ActivityLog[]
  memberships       OrganizationMembership[]
  requestedExports  DataExport[]
  uploadedDocuments Document[]

  @@map("app_users")
}

model OrganizationMembership {
  id             String           @id @default(uuid()) @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  appUserId      String           @map("app_user_id") @db.Uuid
  role           OrganizationRole @default(MEMBER)
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  appUser      AppUser      @relation(fields: [appUserId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, appUserId])
  @@index([appUserId])
  @@map("organization_memberships")
}

model ActivityLog {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  actorUserId    String?  @map("actor_user_id") @db.Uuid
  action         String
  targetType     String?  @map("target_type")
  targetId       String?  @map("target_id")
  ipAddress      String?  @map("ip_address")
  userAgent      String?  @map("user_agent")
  createdAt      DateTime @default(now()) @map("created_at")

  actorUser    AppUser?     @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([actorUserId])
  @@map("activity_logs")
}

model Customer {
  id              String   @id @default(uuid()) @db.Uuid
  organizationId  String   @map("organization_id") @db.Uuid
  companyName     String   @map("company_name")
  contactName     String?  @map("contact_name")
  email           String?
  phone           String?
  country         String?
  preferredLocale String   @default("en") @map("preferred_locale")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  machines     Machine[]
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, companyName])
  @@index([organizationId])
  @@map("customers")
}

model MachineModel {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  modelName      String   @map("model_name")
  description    String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  machines     Machine[]
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, modelName])
  @@index([organizationId])
  @@map("machine_models")
}

model Machine {
  id             String        @id @default(uuid()) @db.Uuid
  organizationId String        @map("organization_id") @db.Uuid
  customerId     String        @map("customer_id") @db.Uuid
  machineModelId String        @map("machine_model_id") @db.Uuid
  machineName    String        @map("machine_name")
  serialNumber   String        @map("serial_number")
  deliveryDate   DateTime?     @map("delivery_date")
  plcType        String?       @map("plc_type")
  hmiType        String?       @map("hmi_type")
  status              MachineStatus @default(ACTIVE)
  qrToken             String?       @unique @map("qr_token")
  qrPinEnabled        Boolean       @default(false) @map("qr_pin_enabled")
  qrPinHash           String?       @map("qr_pin_hash")
  portalDefaultLocale String        @default("en") @map("portal_default_locale")
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")

  customer     Customer     @relation(fields: [customerId], references: [id], onDelete: Restrict)
  dataExports  DataExport[]
  documents    Document[]
  machineModel MachineModel @relation(fields: [machineModelId], references: [id], onDelete: Restrict)
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  serviceTickets ServiceTicket[]
  softwareVersions SoftwareVersion[]
  spareParts   SparePart[]
  quoteRequests QuoteRequest[]

  @@unique([organizationId, serialNumber])
  @@unique([organizationId, id])
  @@index([organizationId, status])
  @@index([organizationId, customerId])
  @@index([organizationId, machineModelId])
  @@map("machines")
}

model Document {
  id                       String                        @id @default(uuid()) @db.Uuid
  organizationId           String                        @map("organization_id") @db.Uuid
  machineId                String                        @map("machine_id") @db.Uuid
  fileName                 String                        @map("file_name")
  storagePath              String                        @map("storage_path")
  fileType                 String                        @map("file_type")
  category                 DocumentCategory
  suggestedCategory        DocumentCategory?             @map("suggested_category")
  classificationConfidence Int?                          @map("classification_confidence")
  classificationStatus     DocumentClassificationStatus  @default(UNCLASSIFIED) @map("classification_status")
  classificationSource     DocumentClassificationSource? @map("classification_source")
  visibilityLevel          DocumentVisibilityLevel       @default(INTERNAL) @map("visibility_level")
  visibleToCustomer        Boolean                       @default(false) @map("visible_to_customer")
  language                 DocumentLanguage              @default(UNKNOWN)
  checksum                 String
  uploadedByUserId         String?                       @map("uploaded_by") @db.Uuid
  uploadedAt               DateTime                      @default(now()) @map("uploaded_at")
  lastDownloadUrlIssuedAt  DateTime?                     @map("last_download_url_issued_at")
  createdAt                DateTime                      @default(now()) @map("created_at")
  updatedAt                DateTime                      @updatedAt @map("updated_at")

  machine        Machine      @relation(fields: [organizationId, machineId], references: [organizationId, id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  uploadedByUser AppUser?     @relation(fields: [uploadedByUserId], references: [id], onDelete: SetNull)

  @@unique([organizationId, storagePath])
  @@index([organizationId, machineId])
  @@index([organizationId, category])
  @@index([organizationId, classificationStatus])
  @@index([organizationId, suggestedCategory])
  @@index([organizationId, visibilityLevel])
  @@index([uploadedByUserId])
  @@map("documents")
}

model DataExport {
  id                  String             @id @default(uuid()) @db.Uuid
  organizationId      String             @map("organization_id") @db.Uuid
  machineId           String             @map("machine_id") @db.Uuid
  requestedByUserId   String?            @map("requested_by") @db.Uuid
  audience            DataExportAudience @default(CUSTOMER_HANDOVER)
  checklistVersion    String             @map("checklist_version")
  manifest            Json
  result              DataExportResult   @default(PENDING)
  artifactStoragePath String?            @map("artifact_storage_path")
  archiveChecksum     String?            @map("archive_checksum")
  archiveByteLength   Int?               @map("archive_byte_length")
  documentCount       Int?               @map("document_count")
  totalDocumentBytes  Int?               @map("total_document_bytes")
  completedAt         DateTime?          @map("completed_at")
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")

  machine         Machine      @relation(fields: [organizationId, machineId], references: [organizationId, id], onDelete: Cascade)
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  requestedByUser AppUser?     @relation(fields: [requestedByUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, machineId, createdAt])
  @@index([organizationId, result])
  @@index([requestedByUserId])
  @@map("data_exports")
}

model ServiceTicket {
  id                  String    @id @default(dbgenerated("gen_random_uuid()::text"))
  organizationId      String    @map("organization_id") @db.Uuid
  machineId           String    @map("machine_id") @db.Uuid
  customerId          String?   @map("customer_id")
  title               String
  description         String
  status              String    @default("open")
  priority            String    @default("normal")
  createdFromPortal   Boolean   @default(false) @map("created_from_portal")
  customerAccessToken String?   @unique @map("customer_access_token")
  meetingLink         String?   @map("meeting_link")
  meetingNotes        String?   @map("meeting_notes")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  organization        Organization @relation(fields: [organizationId], references: [id])
  machine             Machine      @relation(fields: [machineId], references: [id])
  comments            TicketComment[]
  @@map("service_tickets")
}

model TicketComment {
  id                    String   @id @default(dbgenerated("gen_random_uuid()::text"))
  organizationId        String   @map("organization_id") @db.Uuid
  ticketId              String   @map("ticket_id")
  authorType            String   @map("author_type")
  message               String
  internalOnly          Boolean  @default(false) @map("internal_only")
  attachmentUrl         String?  @map("attachment_url")
  attachmentStoragePath String?  @map("attachment_storage_path")
  createdAt             DateTime @default(now()) @map("created_at")
  organization          Organization @relation(fields: [organizationId], references: [id])
  ticket                ServiceTicket @relation(fields: [ticketId], references: [id])
  @@map("ticket_comments")
}

model SoftwareVersion {
  id                    String   @id @default(dbgenerated("gen_random_uuid()::text"))
  organizationId        String   @map("organization_id") @db.Uuid
  machineId             String   @map("machine_id") @db.Uuid
  versionName           String   @map("version_name")
  softwareType          String   @map("software_type")
  notes                 String?
  isDeliveredVersion    Boolean  @default(false) @map("is_delivered_version")
  isCurrentKnownVersion Boolean  @default(false) @map("is_current_known_version")
  storagePath           String?  @map("storage_path")
  checksum              String?
  uploadedByUserId      String?  @map("uploaded_by_user_id") @db.Uuid
  uploadedAt            DateTime @default(now()) @map("uploaded_at")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  organization          Organization @relation(fields: [organizationId], references: [id])
  machine               Machine      @relation(fields: [machineId], references: [id])

  @@index([organizationId])
  @@index([machineId])
  @@index([machineId, softwareType])
  @@map("software_versions")
}

model SparePart {
  id                  String    @id @default(dbgenerated("gen_random_uuid()::text"))
  organizationId      String    @map("organization_id") @db.Uuid
  machineId           String    @map("machine_id") @db.Uuid
  partName            String    @map("part_name")
  manufacturer        String?
  partNumber          String?   @map("part_number")
  quantity            Int       @default(1)
  category            String    @default("other")
  criticality         String    @default("recommended")
  estimatedPrice      Decimal?  @map("estimated_price") @db.Decimal(12,2)
  currency            String    @default("EUR")
  internalCost        Decimal?  @map("internal_cost") @db.Decimal(12,2)
  customerVisiblePrice Decimal? @map("customer_visible_price") @db.Decimal(12,2)
  sourceDocumentId    String?   @map("source_document_id") @db.Uuid
  notes               String?
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  organization        Organization @relation(fields: [organizationId], references: [id])
  machine             Machine      @relation(fields: [machineId], references: [id])
  @@map("spare_parts")
}

model QuoteRequest {
  id                  String    @id @default(dbgenerated("gen_random_uuid()::text"))
  organizationId      String    @map("organization_id") @db.Uuid
  machineId           String    @map("machine_id") @db.Uuid
  sparePartId         String?   @map("spare_part_id")
  ticketId            String?   @map("ticket_id")
  type                String    @default("spare-part")
  title               String
  description         String?
  quotedPrice         Decimal?  @map("quoted_price") @db.Decimal(12,2)
  currency            String    @default("EUR")
  status              String    @default("requested")
  customerAccessToken String?   @unique @map("customer_access_token")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  organization        Organization @relation(fields: [organizationId], references: [id])
  machine             Machine      @relation(fields: [machineId], references: [id])
  @@map("quote_requests")
}
