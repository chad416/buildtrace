generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum OrganizationRole {
  OWNER
  ADMIN
  MEMBER
}

enum MachineStatus {
  ACTIVE
  MAINTENANCE
  OUT_OF_SERVICE
  ARCHIVED
}

model Organization {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  activityLogs  ActivityLog[]
  customers     Customer[]
  machineModels MachineModel[]
  machines      Machine[]
  memberships   OrganizationMembership[]

  @@map("organizations")
}

model AppUser {
  id          String   @id @default(uuid()) @db.Uuid
  authUserId  String   @unique @map("auth_user_id") @db.Uuid
  email       String   @unique
  displayName String?  @map("display_name")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  activityLogs ActivityLog[]
  memberships  OrganizationMembership[]

  @@map("app_users")
}

model OrganizationMembership {
  id             String           @id @default(uuid()) @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  appUserId      String           @map("app_user_id") @db.Uuid
  role           OrganizationRole @default(MEMBER)
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  appUser      AppUser      @relation(fields: [appUserId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, appUserId])
  @@index([appUserId])
  @@map("organization_memberships")
}

model ActivityLog {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  actorUserId    String?  @map("actor_user_id") @db.Uuid
  action         String
  targetType     String?  @map("target_type")
  targetId       String?  @map("target_id")
  ipAddress      String?  @map("ip_address")
  userAgent      String?  @map("user_agent")
  createdAt      DateTime @default(now()) @map("created_at")

  actorUser    AppUser?     @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([actorUserId])
  @@map("activity_logs")
}

model Customer {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  name           String
  externalRef    String?  @map("external_ref")
  email          String?
  phone          String?
  notes          String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  machines     Machine[]
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("customers")
}

model MachineModel {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  manufacturer   String
  name           String
  modelCode      String?  @map("model_code")
  description    String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  machines     Machine[]
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, manufacturer, name])
  @@index([organizationId])
  @@map("machine_models")
}

model Machine {
  id             String        @id @default(uuid()) @db.Uuid
  organizationId String        @map("organization_id") @db.Uuid
  customerId     String        @map("customer_id") @db.Uuid
  machineModelId String        @map("machine_model_id") @db.Uuid
  serialNumber   String        @map("serial_number")
  name           String?
  status         MachineStatus @default(ACTIVE)
  installedAt    DateTime?     @map("installed_at")
  location       String?
  notes          String?
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  customer     Customer     @relation(fields: [customerId], references: [id], onDelete: Restrict)
  machineModel MachineModel @relation(fields: [machineModelId], references: [id], onDelete: Restrict)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, serialNumber])
  @@index([organizationId, status])
  @@index([organizationId, customerId])
  @@index([organizationId, machineModelId])
  @@map("machines")
}
