generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum OrganizationRole {
  OWNER
  ADMIN
  MEMBER
}

enum MachineStatus {
  ACTIVE
  MAINTENANCE
  OUT_OF_SERVICE
  ARCHIVED
}

enum DocumentCategory {
  PLC
  HMI
  MECHANICAL_DRAWINGS
  ELECTRICAL_DRAWINGS
  CAD
  MACHINE_PHOTOS
  FAT
  SAT
  MANUALS
  SAFETY_INSTRUCTIONS
  SUPPLIER_DOCUMENTS
  SPARE_PARTS_BOM
  CERTIFICATES
  SERVICE_NOTES
  OTHER
}

enum DocumentVisibilityLevel {
  CUSTOMER_VISIBLE
  INTERNAL
  SENSITIVE_ENGINEERING
  RESTRICTED
}

enum DocumentLanguage {
  EN
  CS
  SK
  PL
  DE
  FR
  ES
  UNKNOWN
}

model Organization {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  activityLogs  ActivityLog[]
  customers     Customer[]
  documents     Document[]
  machineModels MachineModel[]
  machines      Machine[]
  memberships   OrganizationMembership[]

  @@map("organizations")
}

model AppUser {
  id          String   @id @default(uuid()) @db.Uuid
  authUserId  String   @unique @map("auth_user_id") @db.Uuid
  email       String   @unique
  displayName String?  @map("display_name")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  activityLogs      ActivityLog[]
  memberships       OrganizationMembership[]
  uploadedDocuments Document[]

  @@map("app_users")
}

model OrganizationMembership {
  id             String           @id @default(uuid()) @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  appUserId      String           @map("app_user_id") @db.Uuid
  role           OrganizationRole @default(MEMBER)
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  appUser      AppUser      @relation(fields: [appUserId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, appUserId])
  @@index([appUserId])
  @@map("organization_memberships")
}

model ActivityLog {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  actorUserId    String?  @map("actor_user_id") @db.Uuid
  action         String
  targetType     String?  @map("target_type")
  targetId       String?  @map("target_id")
  ipAddress      String?  @map("ip_address")
  userAgent      String?  @map("user_agent")
  createdAt      DateTime @default(now()) @map("created_at")

  actorUser    AppUser?     @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([actorUserId])
  @@map("activity_logs")
}

model Customer {
  id              String   @id @default(uuid()) @db.Uuid
  organizationId  String   @map("organization_id") @db.Uuid
  companyName     String   @map("company_name")
  contactName     String?  @map("contact_name")
  email           String?
  phone           String?
  country         String?
  preferredLocale String   @default("en") @map("preferred_locale")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  machines     Machine[]
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, companyName])
  @@index([organizationId])
  @@map("customers")
}

model MachineModel {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  modelName      String   @map("model_name")
  description    String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  machines     Machine[]
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, modelName])
  @@index([organizationId])
  @@map("machine_models")
}

model Machine {
  id             String        @id @default(uuid()) @db.Uuid
  organizationId String        @map("organization_id") @db.Uuid
  customerId     String        @map("customer_id") @db.Uuid
  machineModelId String        @map("machine_model_id") @db.Uuid
  machineName    String        @map("machine_name")
  serialNumber   String        @map("serial_number")
  deliveryDate   DateTime?     @map("delivery_date")
  plcType        String?       @map("plc_type")
  hmiType        String?       @map("hmi_type")
  status         MachineStatus @default(ACTIVE)
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  customer     Customer     @relation(fields: [customerId], references: [id], onDelete: Restrict)
  documents    Document[]
  machineModel MachineModel @relation(fields: [machineModelId], references: [id], onDelete: Restrict)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, serialNumber])
  @@unique([organizationId, id])
  @@index([organizationId, status])
  @@index([organizationId, customerId])
  @@index([organizationId, machineModelId])
  @@map("machines")
}

model Document {
  id                      String                  @id @default(uuid()) @db.Uuid
  organizationId          String                  @map("organization_id") @db.Uuid
  machineId               String                  @map("machine_id") @db.Uuid
  fileName                String                  @map("file_name")
  storagePath             String                  @map("storage_path")
  fileType                String                  @map("file_type")
  category                DocumentCategory
  visibilityLevel         DocumentVisibilityLevel @default(INTERNAL) @map("visibility_level")
  visibleToCustomer       Boolean                 @default(false) @map("visible_to_customer")
  language                DocumentLanguage        @default(UNKNOWN)
  checksum                String
  uploadedByUserId        String?                 @map("uploaded_by") @db.Uuid
  uploadedAt              DateTime                @default(now()) @map("uploaded_at")
  lastDownloadUrlIssuedAt DateTime?               @map("last_download_url_issued_at")
  createdAt               DateTime                @default(now()) @map("created_at")
  updatedAt               DateTime                @updatedAt @map("updated_at")

  machine        Machine      @relation(fields: [organizationId, machineId], references: [organizationId, id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  uploadedByUser AppUser?     @relation(fields: [uploadedByUserId], references: [id], onDelete: SetNull)

  @@unique([organizationId, storagePath])
  @@index([organizationId, machineId])
  @@index([organizationId, category])
  @@index([organizationId, visibilityLevel])
  @@index([uploadedByUserId])
  @@map("documents")
}
